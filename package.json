{
  "name": "@jamesgmarks/utilities",
  "version": "0.6.3",
  "description": "A series of useful functions, heavily tested and strongly typed via Typescript declarations. Inspired by functional philosophies.",
  "homepage": "https://github.com/jmarks-lws/utilities#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:jmarks-lws/utilities.git"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "jest",
    "test-watch": "jest --watch",
    "coverage": "jest --coverage",
    "build:doc": "npm run build && ts-node src/dev/jsdoc.ts",
    "buildAndPublish": "rm -rf dist && npm run build:doc && npm version patch && git push && npm publish"
  },
  "keywords": [
    "utilities",
    "functional",
    "typescript",
    "array",
    "object",
    "pipe",
    "memoize",
    "immutable"
  ],
  "author": "James Marks <jamesgmarks@gmail.com>",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@babel/cli": "^7.16.8",
    "@babel/core": "^7.16.12",
    "@babel/preset-env": "^7.16.11",
    "@babel/preset-typescript": "^7.16.7",
    "@types/jest": "^29.5.14",
    "@types/jsdoc-to-markdown": "^7.0.3",
    "@types/node": "^13.7.7",
    "@types/object-hash": "^1.3.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^6.8.0",
    "eslint-config-airbnb-base": "14.0.0",
    "eslint-plugin-import": "^2.20.1",
    "jest": "^29.7.0",
    "jsdoc-babel": "^0.5.0",
    "jsdoc-to-markdown": "^7.1.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^8.6.2",
    "typescript": "~4.7.4"
  },
  "dependencies": {}
}
