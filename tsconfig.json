{
    "compilerOptions": {
      "target": "ES2015",
      "module": "node16",
      "resolveJsonModule": true,
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": true,
      "strictNullChecks": true,
      "moduleResolution": "node16",
      "types": [
        "node"
      ],
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "forceConsistentCasingInFileNames": true
    },
    "exclude": [
      "build",
      "dist",
      "coverage",
      "test",
      "src/devTesting",
      "node_modules",
      "tests",
      "vitest.config.ts"
    ]
  }
