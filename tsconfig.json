{
    "compilerOptions": {
      "target": "ES2015",
      "module": "commonjs",
      "resolveJsonModule": true,
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": true,
      "strictNullChecks": true,
      "moduleResolution": "node",
      "baseUrl": ".",
      "paths": {},
      "types": [
        "node",
        "jest"
      ],
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "forceConsistentCasingInFileNames": true
    },
    "preset": "ts-jest",
    "exclude": [
      "build",
      "dist",
      "coverage",
      "test",
      "src/devTesting",
      "node_modules",
      "tests"
    ]
  }
